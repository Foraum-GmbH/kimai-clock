      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Timer lief weiter, während dein Mac inaktiv war. Du kannst die Aufzeichnung fortsetzen oder den Timer stoppen, um die aktuelle Sitzung zu beenden."
